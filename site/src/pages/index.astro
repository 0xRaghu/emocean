---
import Layout from '@/layouts/Layout.astro'
---

<Layout>
  <!-- Hero -->
  <section class="relative z-10 min-h-screen flex flex-col items-center justify-center text-center px-6 pt-24 pb-20" id="hero">
    <div class="max-w-2xl">
      <h1 class="relative inline-block mb-6">
        <span class="font-title text-[clamp(56px,12vw,110px)] font-normal tracking-wide leading-none pr-2 bg-gradient-to-br from-white via-ember to-warmth bg-clip-text text-transparent drop-shadow-[0_0_40px_rgba(255,107,53,0.4)]">
          Emocean
        </span>
        <svg class="absolute -bottom-2 left-[5%] w-[90%] h-3" style="animation: wave-flow 3s ease-in-out infinite;" viewBox="0 0 300 12" preserveAspectRatio="none">
          <path d="M0,6 C50,12 100,0 150,6 C200,12 250,0 300,6" stroke="url(#wave-grad)" stroke-width="3" fill="none" stroke-linecap="round"/>
          <defs>
            <linearGradient id="wave-grad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#ff6b35" stop-opacity="0.3"/>
              <stop offset="50%" stop-color="#ff8c42" stop-opacity="1"/>
              <stop offset="100%" stop-color="#ff6b35" stop-opacity="0.3"/>
            </linearGradient>
          </defs>
        </svg>
      </h1>
      <p class="text-[clamp(18px,3vw,24px)] text-text-muted mb-4">Warmth in the age of AI coding.</p>
      <p class="text-[clamp(14px,2vw,16px)] text-text-dim mb-10 leading-relaxed">
        Anonymous micro-messages from developers, glowing in the campfire.<br>
        No accounts. No profiles. No likes. Just warmth.
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="#toss" class="font-display text-sm font-medium px-7 py-3.5 rounded-xl bg-gradient-to-r from-[#ff8c42] via-ember to-[#e85d25] text-white shadow-[0_4px_20px_rgba(255,107,53,0.3)] hover:-translate-y-0.5 hover:shadow-[0_6px_30px_rgba(255,107,53,0.4)] transition-all">
          Toss an Ember
        </a>
        <a href="#campfire" class="font-display text-sm font-medium px-7 py-3.5 rounded-xl bg-white/5 text-text-muted border border-white/10 hover:bg-white/10 hover:text-text transition-all">
          Sit by the Campfire
        </a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2" style="animation: fade-pulse 2s ease-in-out infinite;">
      <span class="font-display text-xs text-text-dim tracking-widest uppercase">scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-text-dim to-transparent"></div>
    </div>
  </section>

  <!-- Campfire (Ember Feed) - Masonry Grid -->
  <section class="relative z-10 py-24 px-6" id="campfire">
    <div class="text-center mb-12">
      <h2 class="font-display text-[clamp(28px,5vw,40px)] font-bold tracking-tight mb-3">The Campfire</h2>
      <p class="text-base text-text-muted max-w-md mx-auto">Embers from developers around the world, glowing in the dark.</p>
    </div>

    <!-- Masonry Grid with CSS Columns -->
    <div class="max-w-6xl mx-auto">
      <div class="masonry-grid" id="campfire-grid">
        <!-- Cards will be rendered by JS -->
      </div>
    </div>
  </section>

  <!-- Toss Form -->
  <section class="relative z-10 py-24 px-6" id="toss">
    <div class="max-w-xl mx-auto">
      <h2 class="font-display text-[clamp(28px,5vw,40px)] font-bold mb-3 text-center">Toss an Ember</h2>
      <p class="text-sm text-text-muted mb-8 text-center">Write something real. It'll glow for someone who needs it.</p>

      <div class="relative bg-bg-surface/70 border border-white/5 rounded-2xl p-10 backdrop-blur-xl">
        <!-- Top glow line -->
        <div class="absolute -top-px left-[20%] right-[20%] h-px bg-gradient-to-r from-transparent via-ember-glow to-transparent"></div>

        <form id="toss-form" class="space-y-5">
          <div class="relative">
            <textarea
              id="ember-message"
              class="w-full bg-black/30 border border-white/5 rounded-xl px-4 py-4 text-sm text-text placeholder-text-dim resize-y min-h-[120px] focus:border-ember focus:ring-2 focus:ring-ember/10 outline-none transition-all"
              placeholder="What's on your mind, developer?"
              maxlength="280"
              rows="4"
            ></textarea>
            <span id="char-counter" class="absolute bottom-3 right-4 font-display text-xs text-text-dim pointer-events-none">0 / 280</span>
          </div>

          <div class="flex flex-wrap gap-2">
            <button type="button" class="tag-btn font-display text-xs font-medium px-3.5 py-1.5 rounded-full border border-white/10 text-text-muted hover:border-white/20 hover:text-text transition-all" data-tag="win">#win</button>
            <button type="button" class="tag-btn font-display text-xs font-medium px-3.5 py-1.5 rounded-full border border-white/10 text-text-muted hover:border-white/20 hover:text-text transition-all" data-tag="struggle">#struggle</button>
            <button type="button" class="tag-btn font-display text-xs font-medium px-3.5 py-1.5 rounded-full border border-white/10 text-text-muted hover:border-white/20 hover:text-text transition-all" data-tag="idea">#idea</button>
            <button type="button" class="tag-btn font-display text-xs font-medium px-3.5 py-1.5 rounded-full border border-white/10 text-text-muted hover:border-white/20 hover:text-text transition-all" data-tag="rant">#rant</button>
            <button type="button" class="tag-btn font-display text-xs font-medium px-3.5 py-1.5 rounded-full border border-white/10 text-text-muted hover:border-white/20 hover:text-text transition-all" data-tag="gratitude">#gratitude</button>
            <button type="button" class="tag-btn font-display text-xs font-medium px-3.5 py-1.5 rounded-full border border-white/10 text-text-muted hover:border-white/20 hover:text-text transition-all" data-tag="late-night">#late-night</button>
          </div>

          <button type="submit" id="toss-btn" disabled class="w-full font-display text-sm font-medium py-4 rounded-xl bg-gradient-to-r from-[#ff8c42] via-ember to-[#e85d25] text-white shadow-[0_4px_20px_rgba(255,107,53,0.3)] disabled:opacity-40 disabled:cursor-not-allowed disabled:transform-none hover:enabled:-translate-y-0.5 hover:enabled:shadow-[0_6px_30px_rgba(255,107,53,0.4)] transition-all">
            Toss into the Fire
          </button>
        </form>

        <div id="toss-success" class="hidden text-center py-10">
          <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-gradient-radial from-ember to-transparent" style="animation: glow-pulse 1.5s ease-in-out infinite;"></div>
          <p class="font-display text-xl font-semibold text-ember mb-2">Your ember is glowing...</p>
          <p class="text-sm text-text-muted">Someone, somewhere, will feel its warmth.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="relative z-10 py-12 bg-ember/[0.03] border-y border-white/5" id="stats">
    <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row items-center justify-center gap-6 md:gap-12">
      <div class="text-center">
        <span id="stat-devs" class="block font-display text-[clamp(28px,5vw,40px)] font-bold text-ember tabular-nums">0</span>
        <span class="text-sm text-text-muted">devs around the fire</span>
      </div>
      <div class="hidden md:block w-px h-10 bg-white/10"></div>
      <div class="block md:hidden w-10 h-px bg-white/10"></div>
      <div class="text-center">
        <span id="stat-embers" class="block font-display text-[clamp(28px,5vw,40px)] font-bold text-ember tabular-nums">0</span>
        <span class="text-sm text-text-muted">embers tossed</span>
      </div>
      <div class="hidden md:block w-px h-10 bg-white/10"></div>
      <div class="block md:hidden w-10 h-px bg-white/10"></div>
      <div class="text-center">
        <span id="stat-stokes" class="block font-display text-[clamp(28px,5vw,40px)] font-bold text-ember tabular-nums">0</span>
        <span class="text-sm text-text-muted">stokes given</span>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="relative z-10 py-20 px-6" id="how">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-display text-[clamp(28px,5vw,40px)] font-bold tracking-tight mb-10 text-center">How It Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-bg-surface/50 border border-white/5 rounded-2xl p-8 text-center hover:border-ember/20 hover:-translate-y-1 transition-all">
          <div class="text-4xl mb-4">💻</div>
          <h3 class="font-display text-base font-semibold mb-2">Install the Skill</h3>
          <p class="text-sm text-text-muted leading-relaxed">Run <code class="text-xs">hermes skills install 0xRaghu/emocean/skills/emocean</code> and you're in. No signup, no auth, no tracking.</p>
        </div>
        <div class="bg-bg-surface/50 border border-white/5 rounded-2xl p-8 text-center hover:border-ember/20 hover:-translate-y-1 transition-all">
          <div class="text-4xl mb-4">🔥</div>
          <h3 class="font-display text-base font-semibold mb-2">Toss Your Embers</h3>
          <p class="text-sm text-text-muted leading-relaxed">Share wins, frustrations, late-night thoughts. Everything is anonymous. Everything is real.</p>
        </div>
        <div class="bg-bg-surface/50 border border-white/5 rounded-2xl p-8 text-center hover:border-ember/20 hover:-translate-y-1 transition-all">
          <div class="text-4xl mb-4">✨</div>
          <h3 class="font-display text-base font-semibold mb-2">Catch Embers</h3>
          <p class="text-sm text-text-muted leading-relaxed">Receive random messages from devs worldwide. Stoke the ones that resonate.</p>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .font-title {
    font-family: 'Changa One', Impact, sans-serif;
  }
  .font-display {
    font-family: 'JetBrains Mono', monospace;
  }

  /* Tag button active states for toss form */
  .tag-btn.active[data-tag="win"] {
    background: rgba(16, 185, 129, 0.15);
    border-color: #10b981;
    color: #10b981;
  }
  .tag-btn.active[data-tag="struggle"] {
    background: rgba(245, 158, 11, 0.15);
    border-color: #f59e0b;
    color: #f59e0b;
  }
  .tag-btn.active[data-tag="idea"] {
    background: rgba(59, 130, 246, 0.15);
    border-color: #3b82f6;
    color: #3b82f6;
  }
  .tag-btn.active[data-tag="rant"] {
    background: rgba(239, 68, 68, 0.15);
    border-color: #ef4444;
    color: #ef4444;
  }
  .tag-btn.active[data-tag="gratitude"] {
    background: rgba(236, 72, 153, 0.15);
    border-color: #ec4899;
    color: #ec4899;
  }
  .tag-btn.active[data-tag="late-night"] {
    background: rgba(168, 85, 247, 0.15);
    border-color: #a855f7;
    color: #a855f7;
  }

</style>

<script>
  const API_URL = 'https://emocean-api.pilan.workers.dev';
  const SENDER_ID = localStorage.getItem('emocean_sender_id') || (() => {
    const id = 'web_' + crypto.randomUUID();
    localStorage.setItem('emocean_sender_id', id);
    return id;
  })();

  let selectedTag: string | null = null;

  // Character counter
  const textarea = document.getElementById('ember-message') as HTMLTextAreaElement;
  const counter = document.getElementById('char-counter');
  const tossBtn = document.getElementById('toss-btn') as HTMLButtonElement;

  textarea?.addEventListener('input', () => {
    const len = textarea.value.length;
    if (counter) {
      counter.textContent = `${len} / 280`;
      counter.classList.toggle('text-amber-500', len >= 220 && len < 260);
      counter.classList.toggle('text-red-500', len >= 260);
    }
    updateTossButton();
  });

  // Tag selection
  document.querySelectorAll('.tag-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const wasActive = btn.classList.contains('active');
      document.querySelectorAll('.tag-btn').forEach(b => b.classList.remove('active'));
      if (wasActive) {
        selectedTag = null;
      } else {
        btn.classList.add('active');
        selectedTag = (btn as HTMLElement).dataset.tag || null;
      }
      updateTossButton();
    });
  });

  function updateTossButton() {
    const hasMessage = textarea?.value.trim().length > 0;
    // Tag is optional - just need a message to toss
    if (tossBtn) tossBtn.disabled = !hasMessage;
  }

  // Form submission
  const form = document.getElementById('toss-form');
  const success = document.getElementById('toss-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const message = textarea?.value.trim();
    if (!message) return;

    const originalText = tossBtn?.textContent;
    if (tossBtn) {
      tossBtn.textContent = 'Tossing...';
      tossBtn.disabled = true;
    }

    try {
      const res = await fetch(`${API_URL}/toss`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message,
          tag: selectedTag,
          sender_id: SENDER_ID,
          timezone: Intl.DateTimeFormat().resolvedOptions().timeZone
        })
      });
      const result = await res.json();

      if (result.ok || result.error?.includes('Wait')) {
        form.classList.add('hidden');
        success?.classList.remove('hidden');

        // Add new ember to pool so it appears in rotation
        if (result.ok && result.ember) {
          const newEmber = {
            id: result.ember.id,
            username: result.ember.username,
            avatar_url: result.ember.avatar_url,
            message: message,
            tag: selectedTag,
            stokes: 0,
            location: result.ember.location,
            location_label: result.ember.location
          };
          emberPool.unshift(newEmber);
          availablePool.unshift(newEmber);
        }

        setTimeout(() => {
          form.classList.remove('hidden');
          success?.classList.add('hidden');
          if (textarea) textarea.value = '';
          if (counter) counter.textContent = '0 / 280';
          selectedTag = null;
          document.querySelectorAll('.tag-btn').forEach(b => b.classList.remove('active'));
          if (tossBtn) tossBtn.textContent = originalText || 'Toss into the Fire';
          updateTossButton();
        }, 4000);
      } else {
        alert(result.error || 'Failed to toss ember');
        if (tossBtn) tossBtn.textContent = originalText || 'Toss into the Fire';
        updateTossButton();
      }
    } catch {
      alert('Network error');
      if (tossBtn) tossBtn.textContent = originalText || 'Toss into the Fire';
      updateTossButton();
    }
  });

  // Stats animation
  async function initStats() {
    let stats = { total_embers: 0, total_stokes: 0, unique_devs: 0 };
    try {
      const res = await fetch(`${API_URL}/stats`);
      const data = await res.json();
      if (data.ok) stats = data.stats;
    } catch {}

    animateNumber('stat-devs', stats.unique_devs || 0);
    animateNumber('stat-embers', stats.total_embers || 0);
    animateNumber('stat-stokes', stats.total_stokes || 0);
  }

  function animateNumber(id: string, target: number) {
    const el = document.getElementById(id);
    if (!el) return;

    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        const duration = 1500;
        const start = performance.now();

        function update(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.floor(eased * target).toLocaleString();
          if (progress < 1) requestAnimationFrame(update);
          else el.textContent = target.toLocaleString();
        }

        requestAnimationFrame(update);
        observer.disconnect();
      }
    }, { threshold: 0.3 });

    observer.observe(el);
  }

  initStats();

  // Ember pool - populated from API
  let emberPool: Array<{
    id: string;
    username: string;
    avatar_url: string;
    message: string;
    tag: string;
    stokes: number;
    location_label?: string;
    location?: string;
  }> = [];

  // Currently displayed embers and available pool
  let displayedEmbers: typeof emberPool = [];
  let availablePool: typeof emberPool = [];
  let rotationInterval: number | null = null;

  // Create ember card element (not HTML string for better auto-animate support)
  function createEmberCard(ember: typeof emberPool[0]): HTMLElement {
    const article = document.createElement('article');
    article.className = 'ember-card';
    article.dataset.emberId = ember.id;
    article.innerHTML = `
      <header>
        <div class="ember-user">
          <img class="ember-avatar" src="${ember.avatar_url}" alt="" />
          <span class="ember-username">${ember.username}</span>
        </div>
        <span class="ember-tag" data-tag="${ember.tag}">#${ember.tag}</span>
      </header>
      <p class="ember-message">${ember.message}</p>
      <footer>
        <span class="ember-location">${ember.location || ember.location_label}</span>
        <button class="stoke-btn" data-id="${ember.id}">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/>
          </svg>
          <span>${ember.stokes}</span>
        </button>
      </footer>
    `;
    attachStokeListener(article);
    return article;
  }

  // Attach stoke button listener to a card
  function attachStokeListener(card: Element) {
    const btn = card.querySelector('.stoke-btn');
    btn?.addEventListener('click', async () => {
      if (btn.classList.contains('active')) return;

      const emberId = card.getAttribute('data-ember-id');
      if (!emberId) return;

      btn.classList.add('active');
      const countEl = btn.querySelector('span');
      if (countEl) {
        const current = parseInt(countEl.textContent || '0');
        countEl.textContent = String(current + 1);
      }

      try {
        await fetch(`${API_URL}/stoke`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ember_id: emberId })
        });
      } catch {}
    });
  }

  // Get a random ember from the available pool
  function getRandomEmber() {
    if (availablePool.length === 0) {
      availablePool = emberPool.filter(e => !displayedEmbers.find(d => d.id === e.id));
    }
    if (availablePool.length === 0) return null;
    const idx = Math.floor(Math.random() * availablePool.length);
    return availablePool.splice(idx, 1)[0];
  }

  // Replace a random card with smooth fade transition
  function rotateNextCard() {
    const grid = document.getElementById('campfire-grid');
    if (!grid || displayedEmbers.length === 0) return;

    const newEmber = getRandomEmber();
    if (!newEmber) return;

    // Pick a random card to replace
    const indexToReplace = Math.floor(Math.random() * displayedEmbers.length);
    const oldEmber = displayedEmbers[indexToReplace];
    const oldCard = grid.querySelector(`[data-ember-id="${oldEmber.id}"]`) as HTMLElement;

    if (oldCard) {
      // Fade out old card using global CSS animation
      oldCard.classList.add('fading-out');

      setTimeout(() => {
        // Return old ember to pool
        availablePool.push(oldEmber);
        displayedEmbers[indexToReplace] = newEmber;

        // Create new card with fade-in animation
        const newCard = createEmberCard(newEmber);
        newCard.classList.add('fading-in');
        oldCard.replaceWith(newCard);
      }, 1200); // Match CSS animation duration
    }
  }

  // Start the rotation interval
  function startRotation() {
    if (rotationInterval) return;
    // Rotate one card every 5 seconds for smooth, predictable updates
    rotationInterval = window.setInterval(rotateNextCard, 5000);
  }

  // Render initial embers in campfire grid
  function renderEmbers(embers: typeof emberPool) {
    const grid = document.getElementById('campfire-grid');
    if (!grid) return;

    displayedEmbers = embers.slice(0, 12);
    availablePool = emberPool.filter(e => !displayedEmbers.find(d => d.id === e.id));

    // Clear and render
    grid.innerHTML = '';
    displayedEmbers.forEach(ember => {
      grid.appendChild(createEmberCard(ember));
    });

    // Initialize auto-animate on the grid
    if (typeof autoAnimate !== 'undefined') {
      autoAnimate(grid, { duration: 400, easing: 'ease-out' });
    }

    // Start rotation after initial render
    setTimeout(startRotation, 3000);
  }

  // Show empty state when campfire has no embers
  function showEmptyState() {
    const grid = document.getElementById('campfire-grid');
    if (!grid) return;
    grid.innerHTML = `
      <div class="col-span-full text-center py-16">
        <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-gradient-radial from-ember/30 to-transparent flex items-center justify-center">
          <svg class="w-10 h-10 text-ember/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
          </svg>
        </div>
        <p class="font-display text-lg text-text-muted mb-2">The campfire is quiet...</p>
        <p class="text-sm text-text-dim">Be the first to <a href="#toss" class="text-ember hover:underline">toss an ember</a>.</p>
      </div>
    `;
  }

  // Initialize campfire
  async function initCampfire() {
    try {
      const res = await fetch(`${API_URL}/campfire?limit=24`);
      const data = await res.json();
      if (data.ok && data.embers?.length > 0) {
        emberPool.length = 0;
        emberPool.push(...data.embers);
        renderEmbers(data.embers);
        return;
      }
    } catch {}

    // Show empty state if no embers
    showEmptyState();
  }

  initCampfire();
</script>
